{
  "expo": {
    "name": "The Holdouts",
    "slug": "the-holdouts",
    "version": "1.0.0",
    "orientation": "landscape",
    "scheme": "theholdouts",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0d0d0f",
    "splash": {
      "image": "./assets/images/splash.png",
      "backgroundColor": "#0d0d0f",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "requireFullScreen": true,
      "bundleIdentifier": "com.theholdouts.app",
      "buildNumber": "1",
      "infoPlist": {
        "UIRequiresFullScreen": true
      }
    },
    "android": {
      "package": "com.theholdouts.app",
      "versionCode": 1,
      "screenOrientation": "landscape",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0d0d0f"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font"
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "newArchEnabled": true,
    "orientationLock": "landscape",
    "icon": "./assets/images/icon.png"
  }
}
